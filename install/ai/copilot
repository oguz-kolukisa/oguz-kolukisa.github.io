#!/bin/bash

set -euo pipefail

# Check if GitHub CLI is installed
if ! command -v gh &>/dev/null; then
  printf "Error: GitHub CLI (gh) is not installed.\n" >&2
  printf "Please install GitHub CLI first using:\n" >&2
  printf "  wget -qO- https://oguz-kolukisa.github.io/install/github | bash\n" >&2
  exit 1
fi

# Base URL for downloading scripts
BASE_URL="https://oguz-kolukisa.github.io"

printf "Downloading copilot.sh script...\n"
TEMP_SCRIPT=$(mktemp)
wget -q "$BASE_URL/scripts/install_scripts/ai/copilot.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  rm -f "$TEMP_SCRIPT"
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
printf "Downloading copilot.sh script... Done\n"

printf "Running GitHub Copilot CLI installation...\n"
bash "$TEMP_SCRIPT"

# Cleanup
rm -f "$TEMP_SCRIPT"

printf "\n"
printf "================================\n"
printf "GitHub Copilot CLI installation complete!\n"
printf "================================\n"
