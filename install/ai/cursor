#!/bin/bash

set -euo pipefail

# Base URL for downloading scripts
BASE_URL="https://oguz-kolukisa.github.io"

printf "Downloading Cursor agent CLI script...\n"
TEMP_SCRIPT=$(mktemp)
wget -q "$BASE_URL/scripts/install_scripts/ai/cursor.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  rm -f "$TEMP_SCRIPT"
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
printf "Downloading Cursor agent CLI script... Done\n"

printf "Running Cursor agent CLI installation...\n"
bash "$TEMP_SCRIPT"

# Cleanup
rm -f "$TEMP_SCRIPT"

printf "\n"
printf "================================\n"
printf "Cursor agent CLI installation complete!\n"
printf "================================\n"
