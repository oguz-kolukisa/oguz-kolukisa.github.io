#!/bin/bash

set -euo pipefail

# Base URL for downloading scripts
BASE_URL="https://oguz-kolukisa.github.io"

printf "Downloading basic.sh script...\n"
TEMP_SCRIPT=$(mktemp)
trap 'rm -f "$TEMP_SCRIPT"' EXIT
wget -q "$BASE_URL/scripts/install_scripts/basic.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
printf "Downloading basic.sh script... Done\n"

printf "Running basic installation...\n"
bash "$TEMP_SCRIPT"

printf "\n"
printf "================================\n"
printf "Basic tools installation complete!\n"
printf "================================\n"
