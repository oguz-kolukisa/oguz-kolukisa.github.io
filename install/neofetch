#!/bin/bash

set -euo pipefail

BASE_URL="https://oguz-kolukisa.github.io"
TEMP_SCRIPT=$(mktemp)
trap 'rm -f "$TEMP_SCRIPT"' EXIT
wget -q "$BASE_URL/scripts/install_scripts/neofetch.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
bash "$TEMP_SCRIPT"
printf "================================\n"
printf "neofetch installation complete!\n"
printf "================================\n"
