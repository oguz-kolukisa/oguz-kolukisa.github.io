#!/bin/bash

set -euo pipefail

# Base URL for downloading scripts
BASE_URL="https://oguz-kolukisa.github.io"

printf "Downloading lsd.sh script...\n"
TEMP_SCRIPT=$(mktemp)
trap 'rm -f "$TEMP_SCRIPT"' EXIT
wget -q "$BASE_URL/scripts/config_settings/lsd.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
printf "Downloading lsd.sh script... Done\n"

# Use shared config if present (so we don't duplicate in bashrc)
[ -f "${HOME}/.config/oguz-setup/shell-config.sh" ] && export OGUZ_SHELL_CONFIG="${HOME}/.config/oguz-setup/shell-config.sh"

printf "Running LSD configuration...\n"
bash "$TEMP_SCRIPT"

printf "\n"
printf "================================\n"
printf "LSD configuration complete!\n"
printf "================================\n"
