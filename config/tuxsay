#!/bin/bash

set -euo pipefail

# Base URL for downloading scripts
BASE_URL="https://oguz-kolukisa.github.io"

printf "Downloading tuxsay.sh script...\n"
TEMP_SCRIPT=$(mktemp)
wget -q "$BASE_URL/scripts/config_settings/tuxsay.sh" -O "$TEMP_SCRIPT"
if [ ! -s "$TEMP_SCRIPT" ]; then
  printf "Error: Failed to download script.\n" >&2
  rm -f "$TEMP_SCRIPT"
  exit 1
fi
chmod +x "$TEMP_SCRIPT"
printf "Downloading tuxsay.sh script... Done\n"

# Use shared config if present (so we don't duplicate in bashrc)
[ -f "${HOME}/.config/oguz-setup/shell-config.sh" ] && export OGUZ_SHELL_CONFIG="${HOME}/.config/oguz-setup/shell-config.sh"

printf "Running Tuxsay configuration...\n"
bash "$TEMP_SCRIPT"

# Cleanup
rm -f "$TEMP_SCRIPT"

printf "\n"
printf "================================\n"
printf "Tuxsay configuration complete!\n"
printf "================================\n"
